{
	"compilerOptions": {
		"paths": {
			"@/*": ["./src/*"]
		},
		"target": "esnext",
		"module": "node16",
		"moduleResolution": "node16",
		"outDir": "./dist",
		"rootDir": ".",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"jsx": "react-jsx"
		// "types": ["vitest", "@testing-library/jest-dom"]
	},
	"include": ["src", "types", "tests"]
}
